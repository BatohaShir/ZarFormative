# ============================================
# Required Environment Variables
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zar_formative?schema=public"
# Direct connection for migrations (bypasses connection pooler)
DIRECT_URL="postgresql://user:password@localhost:5432/zar_formative?schema=public"

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Site URL (used for CSRF validation, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# ============================================
# Optional Environment Variables
# ============================================

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Upstash Redis (for rate limiting in production)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# Cron Secret (for secure cron endpoints)
CRON_SECRET="your-cron-secret-key"

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

# Google Site Verification
GOOGLE_SITE_VERIFICATION="your-verification-code"
